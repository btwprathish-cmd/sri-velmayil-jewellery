{
  "framework": null,
  "installCommand": "npm install -g pnpm@10.26.1 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/web run build",
  "outputDirectory": "apps/web/dist/public",
  "rewrites": [
    { "source": "/api/rates/history", "destination": "/api/rates/history" },
    { "source": "/api/rates/latest",  "destination": "/api/rates/latest" },
    { "source": "/api/rates/:date",   "destination": "/api/rates/[date]" },
    { "source": "/((?!api/).*)",      "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
