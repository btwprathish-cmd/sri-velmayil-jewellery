# Site Configuration
NEXT_PUBLIC_SITE_URL=https://srivelmayiljewellery.com

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console Verification
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# Live Gold/Silver Rates (primary - optional, falls back to gold-api.com)
METALPRICE_API_KEY=your-metalpriceapi-key

# Admin Authentication (REQUIRED in production - min 16 char password, 32 char secret)
ADMIN_USERNAME=velmayil_admin
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!
ADMIN_SESSION_SECRET=change-this-to-a-random-64-character-secret-string-for-production

# Cloudinary CDN (REQUIRED for production image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
